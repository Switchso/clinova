PORT=3000
HOST=0.0.0.0
DATABASE_PATH=./data/clinic.sqlite
DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_CONNECTION_TIMEOUT_MS=10000
SESSION_SECRET=change-this-long-random-secret-before-production
COOKIE_SECURE=false
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION=14
BACKUP_TIME=02:00
BACKUP_RUN_ON_START=false
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
WHATSAPP_ENABLED=false
WHATSAPP_DRY_RUN=false
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_DEFAULT_COUNTRY_CODE=972
