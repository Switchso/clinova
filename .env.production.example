PORT=3000
HOST=127.0.0.1
DATABASE_PATH=./data/clinic.sqlite
DATABASE_URL=postgres://clinova_user:CHANGE_ME@127.0.0.1:5432/clinova
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_CONNECTION_TIMEOUT_MS=10000
SESSION_SECRET=replace-with-a-long-random-secret-at-least-48-chars
COOKIE_SECURE=true
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION=14
BACKUP_TIME=02:00
BACKUP_RUN_ON_START=false
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
WHATSAPP_ENABLED=false
WHATSAPP_DRY_RUN=false
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_DEFAULT_COUNTRY_CODE=972
